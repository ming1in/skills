{
  "name": "ming-skills",
  "description": "Reusable agent skills and workflows by Ming Lin.",
  "version": "0.4.0",
  "author": {
    "name": "Ming Lin"
  },
  "homepage": "https://github.com/ming1in/skills",
  "repository": "https://github.com/ming1in/skills",
  "license": "MIT",
  "keywords": [
    "agent-skills",
    "claude-code",
    "codex",
    "opencode",
    "automation"
  ],
  "skills": [
    "./skills/"
  ],
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/skills/afk/scripts/afk-stop-hook.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/skills/afk/scripts/afk-session-end.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/skills/afk/scripts/afk-session-start.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
